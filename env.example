PORT=8080
PUBLIC_BASE_URL=https://your-domain.example.com
BOOTSTRAP_APIKEY=your_full_bootstrap_apikey
MYSQL_DSN=your_mysql_user:your_mysql_password@tcp(127.0.0.1:3306)/your_mysql_database?charset=utf8mb4&parseTime=True&loc=Local
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=admin@example.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=admin@example.com
COOKIE_ADMIN_PASSWORD=your_cookie_admin_password
APIKEY_ADMIN_PAGE_PASSWORD=your_apikey_admin_page_password
# HOME_PAGE_PASSWORD 留空或保持 your_home_page_password 表示不启用首页访问密码；改成自定义值后启用
HOME_PAGE_PASSWORD=your_home_page_password
# APIKEY_APPLY_ONCE_PER_EMAIL=1 表示每个 QQ 邮箱只能领取一次；设置为 0/false/no/off/unlimited 表示允许同一邮箱重复领取
APIKEY_APPLY_ONCE_PER_EMAIL=1
# OPENAPI_DOC_SYNC_ENABLED=1 表示让 /openapi.json 和 Swagger 文档 servers 按当前访问域名动态同步；默认 0
OPENAPI_DOC_SYNC_ENABLED=0
# JOB_WORKER_COUNT=4 表示启动 4 个异步任务 worker；默认 1，最大 16
JOB_WORKER_COUNT=1